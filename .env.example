# Скопируй в .env и заполни реальными значениями:
# cp .env.example .env

# Пароль к PostgreSQL (придумай надёжный)
DB_PASSWORD=change_me_strong_password

# JWT секрет — минимум 32 символа, генерируй случайно:
# openssl rand -base64 32
JWT_SECRET=change_me_min_32_chars_long_secret_key!!

# Домен твоего фронтенда (для CORS)
# Если фронтенда нет — оставь пустым или убери из docker-compose
CORS_ORIGINS=https://yourdomain.com

# Домен API (Caddy получит SSL-сертификат автоматически)
DOMAIN=api.yourdomain.com
